# FoodMarket Database Configuration
# Copy this to .env and fill in your values

# Database Host (localhost for XAMPP)
DB_HOST=localhost

# Database Name
DB_NAME=restaurant_management_db

# Database User (use 'root' for XAMPP, NOT 'pma')
DB_USER=root

# Database Password (empty for XAMPP by default)
DB_PASS=

# Application Debug Mode
APP_DEBUG=false

# Transak Gateway Credentials
TRANSAK_API_KEY=your_api_key_here
TRANSAK_API_SECRET=your_api_secret_here
TRANSAK_BASE_URL=https://api.transak.com/v1
TRANSAK_WEBHOOK_SECRET=your_webhook_secret_here
